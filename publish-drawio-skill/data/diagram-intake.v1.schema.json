{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/diagram-intake.v1.schema.json",
  "title": "Host-owned diagram intake v1",
  "type": "object",
  "required": [
    "schema_version", "intake_id", "mode", "request_sha256", "status",
    "classification", "questions", "answers", "assumptions", "completeness"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "intake_id": {"$ref": "#/$defs/id"},
    "mode": {"enum": ["create", "improve", "preserve", "local_reflow", "full_reflow"]},
    "request_sha256": {"$ref": "#/$defs/sha"},
    "status": {"enum": ["pending", "awaiting_input", "complete", "needs_human"]},
    "classification": {"$ref": "#/$defs/classification"},
    "questions": {
      "type": "array",
      "items": {"$ref": "#/$defs/question"}
    },
    "answers": {
      "type": "array",
      "items": {"$ref": "#/$defs/answer"}
    },
    "assumptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/assumption"}
    },
    "completeness": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "diagramType": {
      "enum": [
        "flowchart", "bpmn", "c4", "er", "dependency",
        "sequence", "roadmap", "git-flow", "generic"
      ]
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1}
      }
    },
    "classification": {
      "type": "object",
      "required": ["selected", "source", "confidence", "candidates"],
      "additionalProperties": false,
      "properties": {
        "selected": {
          "oneOf": [{"$ref": "#/$defs/diagramType"}, {"type": "null"}]
        },
        "source": {"enum": ["explicit", "existing", "analysis", "human", "pending"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "candidates": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/diagramType"}
        }
      }
    },
    "question": {
      "type": "object",
      "required": [
        "question_id", "kind", "prompt", "reason", "recommended",
        "choices", "allow_free_text"
      ],
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^question-[a-f0-9]{20}$"
        },
        "kind": {
          "enum": [
            "classification", "semantic", "consolidated",
            "assumption_acceptance"
          ]
        },
        "prompt": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "recommended": {"$ref": "#/$defs/option"},
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/option"}
        },
        "allow_free_text": {"const": true}
      }
    },
    "answer": {
      "type": "object",
      "required": ["question_id", "text"],
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^question-[a-f0-9]{20}$"
        },
        "text": {"type": "string"}
      }
    },
    "assumption": {
      "type": "object",
      "required": ["note_id", "text", "accepted"],
      "additionalProperties": false,
      "properties": {
        "note_id": {
          "type": "string",
          "pattern": "^assumption-[a-f0-9]{20}$"
        },
        "text": {"type": "string", "minLength": 1},
        "accepted": {"type": "boolean"}
      }
    }
  }
}
