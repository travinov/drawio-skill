{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/diagram-intake-analysis.v1.schema.json",
  "title": "Semantic Analyst intake proposal v1",
  "type": "object",
  "required": ["schema_version", "role", "status", "result"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "role": {"const": "semantic_analyst"},
    "status": {"enum": ["ok", "needs_human", "failed"]},
    "result": {"$ref": "#/$defs/result"}
  },
  "$defs": {
    "diagramType": {
      "enum": [
        "flowchart", "bpmn", "c4", "er", "dependency",
        "sequence", "roadmap", "git-flow", "generic"
      ]
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1}
      }
    },
    "questionProposal": {
      "type": "object",
      "required": ["prompt", "reason", "recommended", "choices", "allow_free_text"],
      "additionalProperties": false,
      "properties": {
        "prompt": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "recommended": {"$ref": "#/$defs/option"},
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/option"}
        },
        "allow_free_text": {"const": true}
      }
    },
    "result": {
      "type": "object",
      "required": [
        "diagram_type", "confidence", "alternatives", "sufficient",
        "blocking_questions", "assumptions"
      ],
      "additionalProperties": false,
      "properties": {
        "diagram_type": {"$ref": "#/$defs/diagramType"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "alternatives": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/diagramType"}
        },
        "sufficient": {"type": "boolean"},
        "blocking_questions": {
          "type": "array",
          "items": {"$ref": "#/$defs/questionProposal"}
        },
        "assumptions": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
