{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/layout-request.v1.schema.json",
  "title": "Deterministic layout request v1", "type": "object",
  "required": ["schema_version", "request_id", "run_id", "semantic_plan_sha256", "diagram_type", "direction", "mode", "backend", "strategy", "quality_profile_version", "pages", "scope", "constraints"], "additionalProperties": false,
  "properties": {"schema_version": {"const": 1}, "request_id": {"$ref": "#/$defs/id"}, "run_id": {"$ref": "#/$defs/id"}, "semantic_plan_sha256": {"$ref": "#/$defs/sha"}, "diagram_type": {"$ref": "#/$defs/diagramType"}, "direction": {"enum": ["TB", "LR"]}, "mode": {"$ref": "#/$defs/layoutMode"}, "backend": {"$ref": "#/$defs/id"}, "strategy": {"$ref": "#/$defs/id"}, "quality_profile_version": {"$ref": "#/$defs/id"}, "pages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/page"}}, "scope": {"$ref": "#/$defs/scope"}, "constraints": {"$ref": "#/$defs/constraints"}},
  "$defs": {
    "id": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "number": {"type": "number"},
    "diagramType": {"enum": ["flowchart", "bpmn", "c4", "er", "dependency", "sequence", "roadmap", "git-flow", "generic"]}, "layoutMode": {"enum": ["create", "preserve", "local_reflow", "full_reflow"]},
    "point": {"type": "object", "required": ["x", "y"], "additionalProperties": false, "properties": {"x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}}},
    "node": {"type": "object", "required": ["node_id", "x", "y", "width", "height", "locked"], "additionalProperties": false, "properties": {"node_id": {"$ref": "#/$defs/id"}, "x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}, "width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}, "locked": {"type": "boolean"}}},
    "edge": {"type": "object", "required": ["edge_id", "source", "target", "edge_class", "source_port", "target_port", "waypoints"], "additionalProperties": false, "properties": {"edge_id": {"$ref": "#/$defs/id"}, "source": {"$ref": "#/$defs/id"}, "target": {"$ref": "#/$defs/id"}, "edge_class": {"enum": ["main", "branch", "feedback", "self_loop"]}, "source_port": {"enum": ["north", "east", "south", "west"]}, "target_port": {"enum": ["north", "east", "south", "west"]}, "waypoints": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/point"}}}},
    "page": {"type": "object", "required": ["page_id", "name", "nodes", "edges"], "additionalProperties": false, "properties": {"page_id": {"$ref": "#/$defs/id"}, "name": {"type": "string"}, "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}}, "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}}}},
    "scope": {"type": "object", "required": ["page_ids", "node_ids", "edge_ids", "movable_nodes", "reroutable_edges"], "additionalProperties": false, "properties": {"page_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "node_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "edge_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "movable_nodes": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "reroutable_edges": {"type": "array", "items": {"$ref": "#/$defs/id"}}}},
    "constraints": {"type": "object", "required": ["grid_size", "node_separation", "layer_separation"], "additionalProperties": false, "properties": {"grid_size": {"type": "number", "exclusiveMinimum": 0}, "node_separation": {"type": "number", "minimum": 0}, "layer_separation": {"type": "number", "minimum": 0}}}
  }
}
