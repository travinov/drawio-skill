{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/layout-request.v1.schema.json",
  "title": "Deterministic layout request v1", "type": "object",
  "required": ["schema_version", "request_id", "run_id", "semantic_plan_sha256", "diagram_type", "direction", "mode", "backend", "strategy", "quality_profile_version", "pages", "scope", "constraints"], "additionalProperties": false,
  "properties": {"schema_version": {"const": 1}, "request_id": {"$ref": "#/$defs/id"}, "run_id": {"$ref": "#/$defs/id"}, "semantic_plan_sha256": {"$ref": "#/$defs/sha"}, "diagram_type": {"$ref": "#/$defs/diagramType"}, "direction": {"enum": ["TB", "LR"]}, "mode": {"$ref": "#/$defs/layoutMode"}, "backend": {"$ref": "#/$defs/id"}, "strategy": {"$ref": "#/$defs/id"}, "strategy_options": {"$ref": "#/$defs/strategyOptions"}, "quality_profile_version": {"enum": [1, 2]}, "pages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/page"}}, "scope": {"$ref": "#/$defs/scope"}, "constraints": {"$ref": "#/$defs/constraints"}},
  "$defs": {
    "id": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "number": {"type": "number"},
    "diagramType": {"enum": ["flowchart", "bpmn", "c4", "er", "dependency", "sequence", "roadmap", "git-flow", "generic"]}, "layoutMode": {"enum": ["create", "preserve", "local_reflow", "full_reflow"]},
    "point": {"type": "object", "required": ["x", "y"], "additionalProperties": false, "properties": {"x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}}},
    "size": {"type": "object", "required": ["width", "height"], "additionalProperties": false, "properties": {"width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}}},
    "node": {"type": "object", "required": ["node_id", "x", "y", "width", "height", "locked"], "additionalProperties": false, "properties": {"node_id": {"$ref": "#/$defs/id"}, "x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}, "width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}, "locked": {"type": "boolean"}, "element_sha256": {"$ref": "#/$defs/sha"}, "parent_id": {"$ref": "#/$defs/id"}}},
    "edge": {"type": "object", "required": ["edge_id", "source", "target", "edge_class", "source_port", "target_port", "locked"], "additionalProperties": false, "properties": {"edge_id": {"$ref": "#/$defs/id"}, "source": {"$ref": "#/$defs/id"}, "target": {"$ref": "#/$defs/id"}, "edge_class": {"enum": ["main", "branch", "feedback", "self_loop"]}, "source_port": {"enum": ["north", "east", "south", "west"]}, "target_port": {"enum": ["north", "east", "south", "west"]}, "locked": {"type": "boolean", "description": "When true, the source and target ports and the waypoint route are immutable; a complete route is required."}, "element_sha256": {"$ref": "#/$defs/sha"}, "label_size": {"$ref": "#/$defs/size"}, "waypoints": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/point"}}}, "allOf": [{"if": {"properties": {"locked": {"const": true}}, "required": ["locked"]}, "then": {"required": ["waypoints"]}}]},
    "page": {"type": "object", "required": ["page_id", "name", "nodes", "edges"], "additionalProperties": false, "properties": {"page_id": {"$ref": "#/$defs/id"}, "name": {"type": "string"}, "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}}, "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}}}},
    "cellRef": {"type": "object", "required": ["page_id", "cell_id"], "additionalProperties": false, "properties": {"page_id": {"$ref": "#/$defs/id"}, "cell_id": {"$ref": "#/$defs/id"}}},
    "scope": {"type": "object", "required": ["page_ids", "node_refs", "edge_refs", "movable_node_refs", "reroutable_edge_refs"], "additionalProperties": false, "properties": {"page_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "node_refs": {"type": "array", "items": {"$ref": "#/$defs/cellRef"}}, "edge_refs": {"type": "array", "items": {"$ref": "#/$defs/cellRef"}}, "movable_node_refs": {"type": "array", "items": {"$ref": "#/$defs/cellRef"}}, "reroutable_edge_refs": {"type": "array", "items": {"$ref": "#/$defs/cellRef"}}}},
    "strategyOptions": {"type": "object", "additionalProperties": false, "properties": {"spacing": {"type": "number", "exclusiveMinimum": 0}, "port_separation": {"type": "number", "exclusiveMinimum": 0}, "shared_penalty": {"type": "number", "exclusiveMinimum": 0}}},
    "constraints": {"type": "object", "required": ["grid_size", "node_separation", "layer_separation"], "additionalProperties": false, "properties": {"grid_size": {"type": "number", "exclusiveMinimum": 0}, "node_separation": {"type": "number", "minimum": 0}, "layer_separation": {"type": "number", "minimum": 0}}}
  }
}
