{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/validation-receipt.v1.schema.json",
  "title": "Hash-bound draw.io validation receipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "attempt_id",
    "started_at",
    "finished_at",
    "strict",
    "artifact",
    "command",
    "exit_code",
    "validator",
    "outputs",
    "platform",
    "tool_versions",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "receipt_id": {"$ref": "#/$defs/nonEmptyString"},
    "run_id": {"$ref": "#/$defs/nonEmptyString"},
    "attempt_id": {"$ref": "#/$defs/nonEmptyString"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "strict": {"const": true},
    "artifact": {"$ref": "#/$defs/hashedFile"},
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "exit_code": {"type": "integer", "minimum": 0},
    "validator": {"$ref": "#/$defs/validator"},
    "outputs": {"$ref": "#/$defs/outputs"},
    "platform": {"$ref": "#/$defs/platform"},
    "tool_versions": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "result": {"enum": ["passed", "failed"]}
  },
  "allOf": [
    {
      "if": {"properties": {"result": {"const": "passed"}}, "required": ["result"]},
      "then": {"properties": {"exit_code": {"const": 0}}}
    },
    {
      "if": {"properties": {"result": {"const": "failed"}}, "required": ["result"]},
      "then": {"properties": {"exit_code": {"minimum": 1}}}
    }
  ],
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "hashedFile": {
      "type": "object",
      "required": ["path", "sha256", "byte_length"],
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_length": {"type": "integer", "minimum": 0}
      }
    },
    "validator": {
      "type": "object",
      "required": ["name", "version", "path", "file_sha256"],
      "additionalProperties": false,
      "properties": {
        "name": {"$ref": "#/$defs/nonEmptyString"},
        "version": {"$ref": "#/$defs/nonEmptyString"},
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "file_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "outputs": {
      "type": "object",
      "required": ["report", "stdout_sha256", "stderr_sha256"],
      "additionalProperties": false,
      "properties": {
        "report": {"$ref": "#/$defs/hashedFile"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "platform": {
      "type": "object",
      "required": ["system", "release", "machine", "python"],
      "additionalProperties": false,
      "properties": {
        "system": {"$ref": "#/$defs/nonEmptyString"},
        "release": {"$ref": "#/$defs/nonEmptyString"},
        "machine": {"$ref": "#/$defs/nonEmptyString"},
        "python": {"$ref": "#/$defs/nonEmptyString"}
      }
    }
  }
}
