{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/roadmap.schema.json",
  "title": "Roadmap YAML",
  "type": "object",
  "required": ["title", "milestones"],
  "additionalProperties": false,
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "time_scale": {"type": "string", "enum": ["week", "month", "quarter", "date", "order"]},
    "lane_dimension": {"type": "string", "minLength": 1},
    "shift_threshold_days": {"type": "integer", "minimum": 0},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "lanes": {
      "type": "array",
      "items": {"$ref": "#/$defs/lane"},
      "uniqueItems": true
    },
    "outcomes": {
      "type": "array",
      "items": {"$ref": "#/$defs/outcome"},
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "items": {"$ref": "#/$defs/task"},
      "uniqueItems": true
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/milestone"},
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {"$ref": "#/$defs/dependency"},
      "uniqueItems": true
    },
    "baseline": {"$ref": "#/$defs/baseline"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "on_track", "at_risk", "blocked", "done", "cancelled"]
    },
    "lane": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      }
    },
    "outcome": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "metric": {"type": "string"}
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string", "minLength": 1},
        "lane": {"$ref": "#/$defs/id"},
        "start": {"$ref": "#/$defs/date"},
        "end": {"$ref": "#/$defs/date"},
        "status": {"$ref": "#/$defs/status"},
        "risk": {"type": "string"},
        "owner": {"type": "string"},
        "milestones": {"type": "array", "items": {"$ref": "#/$defs/id"}},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}},
        "notes": {"type": "string"}
      }
    },
    "milestone": {
      "type": "object",
      "required": ["id", "title", "date"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string", "minLength": 1},
        "lane": {"$ref": "#/$defs/id"},
        "date": {"$ref": "#/$defs/date"},
        "status": {"$ref": "#/$defs/status"},
        "owner": {"type": "string"},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}},
        "notes": {"type": "string"}
      }
    },
    "dependency": {
      "type": "object",
      "required": ["id", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "from": {"$ref": "#/$defs/id"},
        "to": {"$ref": "#/$defs/id"},
        "type": {"type": "string", "enum": ["blocks", "depends_on", "influences", "relates_to"]},
        "impact": {"type": "string", "enum": ["low", "medium", "high"]},
        "rationale": {"type": "string"}
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {"type": "string"},
        "tasks": {"type": "array", "items": {"$ref": "#/$defs/task"}},
        "milestones": {"type": "array", "items": {"$ref": "#/$defs/milestone"}},
        "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/outcome"}}
      }
    }
  }
}
